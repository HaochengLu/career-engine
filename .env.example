# 复制为 .env 后填写（Vercel 上则在项目 Environment Variables 里配置同名变量）

# 提供方：
# mock = 离线假数据（无需 API key，适合第一次本地启动和改 UI）
# openai = 调用 OpenAI 或 OpenAI 兼容 API（推荐真实生成）
# anthropic = 调用 Anthropic Claude（可选）
LLM_PROVIDER=mock

# Anthropic（仅当 LLM_PROVIDER=anthropic 时需要）
ANTHROPIC_API_KEY=

# 默认模型兜底（worker 未单独配置时使用）
DEFAULT_MODEL=gpt-5.4

# OpenAI 兼容端点（可填官方 OpenAI，也可填 newapi/oneapi 等代理）
OPENAI_API_KEY=
# 多 key 并发分摊：生产推荐使用这个变量，逗号或换行分隔；不要把真实 key 提交到 Git。
OPENAI_API_KEYS=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_PER_KEY_CONCURRENCY=8

# 每个 LLM worker 的推荐 OpenAI 模型。
# 想省成本/提速时，可以把 gpt-5.5 降到 gpt-5.4 或 gpt-5.4-mini。
WORKER_MODEL_PARSE_RESUME=gpt-5.4
WORKER_MODEL_EXTRACT_EVIDENCE=gpt-5.5
WORKER_MODEL_SYNTHESIZE_ROLES=gpt-5.5
WORKER_MODEL_OPPORTUNITY_SCOUT=gpt-5.4
WORKER_MODEL_STRATEGY=gpt-5.5
WORKER_MODEL_RED_TEAM=gpt-5.5

# 联网检索（默认关）：开启后用一次 web_search 为“市场拉动/新兴岗位”召回注入实时市场信号。
# 需 provider=openai 且端点支持 Responses API 的 web_search 工具；失败自动降级为无检索。
ENABLE_WEB_SEARCH=false

# 本地服务端口（Vercel 不需要）
PORT=3000

# 全凭自觉付费：微信收款码图片路径（默认用 public/ 下自带的三张）
PAY_QR_TRIAL=/pay-1.png
PAY_QR_FULL=/pay-10.png
PAY_QR_CUSTOM=/pay-custom.png

# 每日额度：完整报告（¥10 档）每天最多生成多少次；0 表示不限制。
QUOTA_FULL_DAILY_LIMIT=150
QUOTA_TIME_ZONE=Asia/Shanghai

# 生产环境建议配置 Upstash Redis REST，用于跨 Vercel 实例共享每日计数。
# 如果不配置，系统会降级为内存计数，只适合本地开发或单实例测试。
QUOTA_REDIS_REST_URL=
QUOTA_REDIS_REST_TOKEN=
