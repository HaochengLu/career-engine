# 复制为 .env 后填写（Vercel 上则在项目 Environment Variables 里配置同名变量）

# 提供方：mock = 离线假数据（无需 API key，给朋友玩/本地测试/调样式）
#         anthropic = 调用真实 Claude（需要 ANTHROPIC_API_KEY）
LLM_PROVIDER=mock

# 真实调用时需要
ANTHROPIC_API_KEY=

# 默认模型（第一性原理：模型是配置项，不写死在业务逻辑里）
DEFAULT_MODEL=claude-opus-4-8

# OpenAI 兼容端点（用 GPT/代理时）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1

# 联网检索（默认关）：开启后用一次 web_search 为“市场拉动/新兴岗位”召回注入实时市场信号。
# 需 provider=openai 且端点支持 Responses API 的 web_search 工具；失败自动降级为无检索。
ENABLE_WEB_SEARCH=false

# 本地服务端口（Vercel 不需要）
PORT=3000

# 全凭自觉付费：微信收款码图片路径（默认用 public/ 下自带的三张）
PAY_QR_TRIAL=/pay-1.png
PAY_QR_FULL=/pay-10.png
PAY_QR_CUSTOM=/pay-custom.png
