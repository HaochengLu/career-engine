{
  "name": "career-engine",
  "version": "0.1.0",
  "private": true,
  "description": "基于职业证据的 Career Strategy Report Engine（轻产品内测版）",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "cf:build": "esbuild cloudflare/worker.ts --bundle --format=esm --platform=neutral --target=es2022 --external:node:* --main-fields=module,main --minify --outfile=dist/cloudflare-worker.js",
    "cf:deploy": "npm run cf:build && wrangler deploy",
    "eval": "tsx evals/run.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.44.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
